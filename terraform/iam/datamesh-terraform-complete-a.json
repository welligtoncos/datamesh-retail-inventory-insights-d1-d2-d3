{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3DatameshBucket",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::retail-inventory-insights-dev-use1",
        "arn:aws:s3:::retail-inventory-insights-dev-use1/*",
        "arn:aws:s3:::retail-inventory-insights-portal-web-dev-use1",
        "arn:aws:s3:::retail-inventory-insights-portal-web-dev-use1/*"
      ]
    },
    {
      "Sid": "S3ListAccountBuckets",
      "Effect": "Allow",
      "Action": [
        "s3:ListAllMyBuckets",
        "s3:GetBucketLocation"
      ],
      "Resource": "*"
    },
    {
      "Sid": "GlueJobsProject",
      "Effect": "Allow",
      "Action": [
        "glue:GetJob",
        "glue:GetJobs",
        "glue:CreateJob",
        "glue:UpdateJob",
        "glue:DeleteJob",
        "glue:StartJobRun",
        "glue:GetJobRun",
        "glue:GetJobRuns",
        "glue:BatchStopJobRun",
        "glue:TagResource",
        "glue:UntagResource"
      ],
      "Resource": [
        "arn:aws:glue:us-east-1:303238378103:job/retail-inventory-insights-*"
      ]
    },
    {
      "Sid": "GlueCatalogAthena",
      "Effect": "Allow",
      "Action": [
        "glue:GetDatabase",
        "glue:GetDatabases",
        "glue:CreateDatabase",
        "glue:UpdateDatabase",
        "glue:DeleteDatabase",
        "glue:GetTable",
        "glue:GetTables",
        "glue:CreateTable",
        "glue:UpdateTable",
        "glue:DeleteTable",
        "glue:GetPartitions",
        "glue:BatchCreatePartition",
        "glue:BatchDeletePartition",
        "glue:TagResource",
        "glue:UntagResource"
      ],
      "Resource": [
        "arn:aws:glue:us-east-1:303238378103:catalog",
        "arn:aws:glue:us-east-1:303238378103:database/retail_inventory_insights_dev",
        "arn:aws:glue:us-east-1:303238378103:table/retail_inventory_insights_dev/*"
      ]
    },
    {
      "Sid": "AthenaWorkgroup",
      "Effect": "Allow",
      "Action": [
        "athena:CreateWorkGroup",
        "athena:DeleteWorkGroup",
        "athena:GetWorkGroup",
        "athena:UpdateWorkGroup",
        "athena:ListWorkGroups",
        "athena:StartQueryExecution",
        "athena:GetQueryExecution",
        "athena:GetQueryResults",
        "athena:StopQueryExecution",
        "athena:TagResource",
        "athena:UntagResource"
      ],
      "Resource": [
        "arn:aws:athena:us-east-1:303238378103:workgroup/retail-inventory-insights-dev"
      ]
    },
    {
      "Sid": "LambdaReports",
      "Effect": "Allow",
      "Action": [
        "lambda:GetFunction",
        "lambda:GetFunctionConfiguration",
        "lambda:GetFunctionCodeSigningConfig",
        "lambda:GetFunctionEventInvokeConfig",
        "lambda:ListVersionsByFunction",
        "lambda:ListTags",
        "lambda:CreateFunction",
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:DeleteFunction",
        "lambda:PublishVersion",
        "lambda:TagResource",
        "lambda:UntagResource",
        "lambda:AddPermission",
        "lambda:RemovePermission",
        "lambda:GetPolicy"
      ],
      "Resource": "arn:aws:lambda:us-east-1:303238378103:function:retail-inventory-insights-*"
    },
    {
      "Sid": "LambdaList",
      "Effect": "Allow",
      "Action": "lambda:ListFunctions",
      "Resource": "*"
    },
    {
      "Sid": "StepFunctionsProcessarDia",
      "Effect": "Allow",
      "Action": [
        "states:DescribeStateMachine",
        "states:DescribeStateMachineVersion",
        "states:ListStateMachines",
        "states:ListStateMachineVersions",
        "states:CreateStateMachine",
        "states:UpdateStateMachine",
        "states:DeleteStateMachine",
        "states:StartExecution",
        "states:DescribeExecution",
        "states:ListExecutions",
        "states:StopExecution",
        "states:TagResource",
        "states:UntagResource",
        "states:ListTagsForResource"
      ],
      "Resource": [
        "arn:aws:states:us-east-1:303238378103:stateMachine:retail-inventory-insights-*",
        "arn:aws:states:us-east-1:303238378103:execution:retail-inventory-insights-*:*"
      ]
    },
    {
      "Sid": "EventBridgeSchedule",
      "Effect": "Allow",
      "Action": [
        "events:DescribeRule",
        "events:ListRules",
        "events:PutRule",
        "events:DeleteRule",
        "events:EnableRule",
        "events:DisableRule",
        "events:PutTargets",
        "events:RemoveTargets",
        "events:ListTargetsByRule",
        "events:TagResource",
        "events:UntagResource"
      ],
      "Resource": "arn:aws:events:us-east-1:303238378103:rule/retail-inventory-insights-*"
    }
  ]
}
