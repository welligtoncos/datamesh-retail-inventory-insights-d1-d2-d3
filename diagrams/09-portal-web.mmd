%% --- Diagrama 6: Modelo de domínio (entidades que o portal gerencia) ---

erDiagram
    INSUMO ||--o{ PARTICAO_ORIGEM : "carregar_origem_dia"
    PARTICAO_ORIGEM ||--|| PARTICAO_ENRIQUECIDA : "enriquecer_dia"
    PARTICAO_ENRIQUECIDA ||--o{ INSIGHT_D1 : "agrega Product ID"
    PARTICAO_ENRIQUECIDA ||--o{ INSIGHT_D2 : "filtra _stockout _lost"
    PARTICAO_ENRIQUECIDA ||--o{ INSIGHT_D3 : "janela N dt="
    EXECUCAO_PIPELINE ||--|{ PARTICAO_ORIGEM : "processa dt"

    INSUMO {
        string arquivo "retail_store_inventory.csv"
        date uploaded_at
        int linhas
        bool schema_ok "15 colunas"
    }

    PARTICAO_ORIGEM {
        date dt "dt=AAAA-MM-DD"
        int linhas
        string s3_path
    }

    PARTICAO_ENRIQUECIDA {
        date dt
        decimal total_revenue
        int rupturas
        decimal venda_perdida
    }

    INSIGHT_D1 {
        date dado_d1
        string top_produto
        decimal receita_total
    }

    INSIGHT_D2 {
        date dado_d1
        string loja_produto
        decimal lost
    }

    INSIGHT_D3 {
        int janela_dias
        string tendencia "Subindo|Caindo|Estável"
    }

    EXECUCAO_PIPELINE {
        string execution_arn
        date dt
        string status
    }
