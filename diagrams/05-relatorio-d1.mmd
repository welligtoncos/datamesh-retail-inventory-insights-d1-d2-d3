%% Geração do relatório D-1 · Excel

flowchart LR
    EXEC["DATA_EXECUCAO<br/>ex.: 2022-01-02"]
    D1["DIA_DADO = exec - 1 dia<br/>ex.: 2022-01-01"]

    EXEC --> D1
    D1 --> CHK{partição<br/>enriquecida<br/>existe?}
