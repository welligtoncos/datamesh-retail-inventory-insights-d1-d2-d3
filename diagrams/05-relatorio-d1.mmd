    PROC --> READ

    READ --> AGG["groupby Product ID, Category<br/>sum Units Sold · sum _revenue"]
    AGG --> XLS["openpyxl Workbook<br/>insight + tabela + fórmulas"]
    XLS --> OUT["relatorio_D1_exec*_dado*.xlsx"]
